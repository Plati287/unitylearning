using UnityEngine;
using UnityEngine.UI;
using TMPro;

public class mecanica_noche2_gameplay : MonoBehaviour
{
    public contador_noche2_script referencia_contador_noche2;
    public float contador_noche2_referencia_tiempo = 0;
    private float distancia_minima_fuego2 = 10f;
    public script_linterna_antorcha referencia_estado_antorcha_noche2;
    public bool antorcha_estado_noche2;
    public GameObject interfaz_interactuar;
    private bool estado_interfaz_noche2_interactuar = false;
    public Button boton_ui_interactuar_noche2;
    public GameObject[] fuegos2;
    private bool[] fuegos2_usados;
    private int fuego_cercano2 = -1;
    public mecanica_noche1 referencia_verificar_noche12;
    public bool verificar_noche1;
    private bool uso_boton_noche2;
    public float contador_noche2_fuegos2_usados;
    public TextMeshProUGUI contador_texto_noche2_fuegos2_usados;
    public GameObject interfaz_noche2;
    public bool verificar_noche23;
    public GameObject[] velas2;

    void Start()
    {
        fuegos2_usados = new bool[fuegos2.Length];
        boton_ui_interactuar_noche2.onClick.AddListener(boton_funcion_noche2);
        verificar_noche23 = false;
    }

    void Update()
    {
        funcionamiento_noche2();
        funcion_interfaz_interactuar_noche2();
        noche2_noche3();
    }

    void funcionamiento_noche2()
    {
        estado_interfaz_noche2_interactuar = false;
        contador_noche2_referencia_tiempo = referencia_contador_noche2.contador_noche2;
        antorcha_estado_noche2 = referencia_estado_antorcha_noche2.verificar_estado_antorcha;
        verificar_noche1 = referencia_verificar_noche12.verificar_noche12;

        if (contador_noche2_referencia_tiempo == 0) return;

        if (verificar_noche1 == true)
        {
            uso_boton_noche2 = false;
            estado_interfaz_noche2_interactuar = false;
            for (int i = 0; i < fuegos2.Length; i++)
            {
                float distancia_actual_fuegos2 = Vector3.Distance(transform.position, fuegos2[i].transform.position);
                if (distancia_actual_fuegos2 < distancia_minima_fuego2 && antorcha_estado_noche2 == true)
                {
                    uso_boton_noche2 = true;
                    fuego_cercano2 = i;
                    estado_interfaz_noche2_interactuar = true;
                }
            }
        }
    }

    void boton_funcion_noche2()
    {
        if (fuego_cercano2 != -1 && !fuegos2_usados[fuego_cercano2] && uso_boton_noche2 == true)
        {
            fuegos2_usados[fuego_cercano2] = true;
            fuegos2[fuego_cercano2].SetActive(true);
            contador_noche2_fuegos2_usados++;
            fuego_cercano2 = -1;
            contador_texto_noche2_fuegos2_usados.text = contador_noche2_fuegos2_usados + "/6";
        }
    }

    void funcion_interfaz_interactuar_noche2()
    {
        interfaz_interactuar.SetActive(estado_interfaz_noche2_interactuar);
    }

    void noche2_noche3()
    {
        if (contador_noche2_fuegos2_usados == 1)
        {
            interfaz_noche2.SetActive(false);
            interfaz_interactuar.SetActive(false);
            verificar_noche23 = true;
            for (int i = 0; i < fuegos2.Length; i++)
            {
                fuegos2[i].SetActive(false);
            }
            for (int a = 0; a < velas2.Length; a++)
            {
                velas2[a].SetActive(false);
            }
        }
    }
}

