using UnityEngine;
using TMPro;
using UnityEngine.UI;

public class mecanica_noche3 : MonoBehaviour
{
    public contador_noche3 referencia_estado_contador_noche3;
    public float contador_noche3_tiempo;

    public mecanica_noche2_gameplay referencia_noche23;
    public bool verificar_noche23_bool;

    public GameObject interfaz_mision_noche3;
    public Button boton_noche3;

    private bool mostrar_ui_interact_noche3 = false;
    public GameObject[] fuegos_3;
    private bool[] fuegos3_usados;

    private int fuego3_cercano = -1;

    public GameObject[] velas;

    public script_linterna_antorcha referencia_estado_antorcha_noche3;
    public bool verificar_estado_antorcha_3;

    private float distancia_minima_fuego3 = 10f;

    private float contador_fuegos_noche3;

    public TextMeshProUGUI contador_fuegos_noche3_texto;

    public bool noche3terminada;
    public GameObject interfaz_interactuar_noche3;
    private bool interactuar_boton3 = false; //para que el boton funcione

    void Start()
    {
        boton_noche3.onClick.AddListener(boton3_funcion);
        fuegos3_usados = new bool[fuegos_3.Length];
        noche3terminada = false;
    }

    void Update()
    {
        funcionamiento_noche3();
        finalizar_noche3_funcion();
        funcion_interact_interfaz_interact3();
    }

    void funcionamiento_noche3()
    {
        contador_noche3_tiempo = referencia_estado_contador_noche3.contador_tiempo_noche3;
        verificar_noche23_bool = referencia_noche23.verificar_noche23;
        verificar_estado_antorcha_3 = referencia_estado_antorcha_noche3.verificar_estado_antorcha;

        if (contador_noche3_tiempo == 0) return;

        interactuar_boton3 = false;
        mostrar_ui_interact_noche3 = false;

        for (int i = 0; i < fuegos_3.Length; i++)
        {
            if (fuegos_3[i] == null) continue;

            float distancia_actual = Vector3.Distance(
                transform.position,
                fuegos_3[i].transform.position
            );

            if (distancia_actual < distancia_minima_fuego3 &&
                verificar_estado_antorcha_3 == true &&
                contador_noche3_tiempo > 0 && verificar_noche23_bool == true)
            {
                fuego3_cercano = i;
                interactuar_boton3 = true;
                mostrar_ui_interact_noche3 = true;
            }
        }
    }

    void boton3_funcion()
    {
        if (fuego3_cercano != -1 &&
            !fuegos3_usados[fuego3_cercano] &&
            interactuar_boton3 == true)
        {
            fuegos3_usados[fuego3_cercano] = true;
            fuegos_3[fuego3_cercano].SetActive(true);

            contador_fuegos_noche3++;
            fuego3_cercano = -1;

            contador_fuegos_noche3_texto.text = contador_fuegos_noche3 + "/8";
        }
    }

    void finalizar_noche3_funcion()
    {
        if (contador_fuegos_noche3 >= 2 && contador_noche3_tiempo > 0)
        {
            interfaz_mision_noche3.SetActive(false);
            noche3terminada = true;

            for (int i = 0; i < fuegos_3.Length; i++)
                fuegos_3[i].SetActive(false);

            for (int i = 0; i < velas.Length; i++)
                velas[i].SetActive(false);
        }
    }

    void funcion_interact_interfaz_interact3()
    {
        interfaz_interactuar_noche3.SetActive(mostrar_ui_interact_noche3);
    }
}
