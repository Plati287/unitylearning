NOCHE 1
using UnityEngine;
using UnityEngine.UI;
using TMPro;
public class mecanica_noche1 : MonoBehaviour
{
    public contador_noche1_script referencia_estado_contador;
    public float contador_noche1_referencia_tiempo;
    public script_linterna_antorcha referencia_estado_antorcha;
    public bool referencia_atorcha_estado;
    private float distancia_minima_fuego = 10f;
    public GameObject[] fuego;
    private bool[] fuego_gastado;
    private int fuego_cercano = -1;
    public TextMeshProUGUI contador_fuego_texto;
    public GameObject interfaz_interaccion_fuego;
    private bool estados_interaz_fuego;
    private bool estados_distancias_jugador_fuego;
    private float contador_fuegos_quemados = 0;
    public Button boton_interactuar_ui_fuego;
    public GameObject[] velas; //hay que usarlas para luego ocultarlas cuando el contador tenga 4/4 para iniciar noche2
    public bool verificar_noche12;
    public GameObject interfaz_mision1;
    public GameObject interfaz_mision2;

    private bool perdida_noche12_bool;

    void Start()
    {
        fuego_gastado = new bool[fuego.Length];
        interfaz_interaccion_fuego.SetActive(false);
        boton_interactuar_ui_fuego.onClick.AddListener(boton_fuego_funcion);
        verificar_noche12 = false;
        interfaz_mision2.SetActive(false);
        perdida_noche12_bool = true;
        

    }

    void Update()
    {
        noche1();
        funcion_interfaz_interactuar();
        noche1_noche2();
        perdida_noche12();
    }

    void noche1()
    {
        estados_interaz_fuego = false;
        contador_noche1_referencia_tiempo = referencia_estado_contador.contador_noche1;
        referencia_atorcha_estado = referencia_estado_antorcha.verificar_estado_antorcha;
        if(contador_noche1_referencia_tiempo == 0) return;
        estados_distancias_jugador_fuego = false;
        for(int i=0; i<fuego.Length; i++)
        {
            if(fuego[i] == null) continue;
            float distancia_actual_fuegos = Vector3.Distance(transform.position, fuego[i].transform.position);
            if (distancia_actual_fuegos < distancia_minima_fuego && referencia_atorcha_estado == true && contador_noche1_referencia_tiempo > 0)
            {
                estados_distancias_jugador_fuego = true;
                fuego_cercano = i;
                estados_interaz_fuego = true;
            }

        }

    }

    void boton_fuego_funcion()
    {
        if(estados_distancias_jugador_fuego == true)
        {
            if(fuego_cercano != -1 && !fuego_gastado[fuego_cercano])
            {
                fuego_gastado[fuego_cercano] = true;
                fuego[fuego_cercano].SetActive(true);
                fuego_cercano = -1;
                contador_fuegos_quemados++;
                contador_fuego_texto.text = contador_fuegos_quemados+"/4";

            }
        }
    }

    void funcion_interfaz_interactuar()
    {
        interfaz_interaccion_fuego.SetActive(estados_interaz_fuego);
    }

    void noche1_noche2()
    {
        if(contador_fuegos_quemados == 1 && contador_noche1_referencia_tiempo >= 0)
        {
            interfaz_mision1.SetActive(false);
            interfaz_interaccion_fuego.SetActive(false);
            interfaz_mision2.SetActive(true);
            

            verificar_noche12 = true;
            for(int i=0; i<fuego.Length; i++)
            {
                fuego[i].SetActive(false);
            }
            for(int a=0; a<velas.Length; a++)
            {
                velas[a].SetActive(false);
            }
            Debug.Log(verificar_noche12);
            
        }
        if(contador_fuegos_quemados < 4 && contador_noche1_referencia_tiempo <= 0)
        {
            perdida_noche12_bool = true;
            verificar_noche12 = false;
        }
    }

    void perdida_noche12()
{
    if(contador_noche1_referencia_tiempo <= 0 && contador_fuegos_quemados < 4 && perdida_noche12_bool)
    {
        Debug.Log("perdida");

        for(int i = 0; i < fuego.Length; i++)
        {
            fuego_gastado[i] = false;
            if(fuego[i] != null) fuego[i].SetActive(false);
        }

        contador_fuegos_quemados = 0;
        fuego_cercano = -1;
        contador_fuego_texto.text = "0/4";
        referencia_estado_contador.contador_noche1 = 180f;
        perdida_noche12_bool = false;
    }
}
   

    

    
}



